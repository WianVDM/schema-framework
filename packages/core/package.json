{
  "name": "@my-framework/core",
"version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./primitives": {
      "import": "./dist/primitives/index.js",
      "types": "./dist/primitives/index.d.ts"
    },
    "./engine": {
      "import": "./dist/engine/index.js",
      "types": "./dist/engine/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external zod --external react --external @tanstack/react-table --external @tanstack/react-form",
    "dev": "tsup src/index.ts --format esm --dts --watch --external zod --external react --external @tanstack/react-table --external @tanstack/react-form",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24"
  },
  "devDependencies": {
    "@tanstack/react-form": "^1.28.6",
    "@tanstack/react-table": "^8.21.3",
    "@types/react": "^19",
    "react": "^19",
    "tsup": "^8",
    "typescript": "^5.8"
  },
  "peerDependencies": {
    "@tanstack/react-form": ">=1",
    "@tanstack/react-table": ">=8",
    "react": "^19"
  }
}